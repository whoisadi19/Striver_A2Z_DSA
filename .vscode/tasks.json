{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Active C++ File",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/run.bat",
      "args": ["${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
